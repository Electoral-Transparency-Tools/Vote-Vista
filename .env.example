# VoteVista AI configuration (optional).
# If NO key is set, the app runs with a deterministic, data-driven fallback
# summary so the POC works out of the box.

# --- Option A: OpenAI-compatible ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Option A2: Google Gemini via its OpenAI-compatible endpoint (cheapest) ---
# OPENAI_API_KEY=<your-gemini-key>
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_MODEL=gemini-2.5-flash-lite

# --- Option B: Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Optional: live web search for the MLA research agent (Feature 5) ---
# If unset, the research agent uses the curated files in sources/ instead.
# Free tier: 1,000 searches/month (https://app.tavily.com).
# TAVILY_API_KEY=tvly-...
