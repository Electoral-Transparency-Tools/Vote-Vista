{
  "name": "vote-vista",
  "version": "0.1.0",
  "private": true,
  "description": "VoteVista - electoral candidate visualization portal (POC: C.V. Raman Nagar, AC 161)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "node --env-file=.env.local scripts/seed.mjs",
    "db:seed:constituencies": "node --env-file=.env.local scripts/seed-constituencies.mjs",
    "db:seed:candidates": "node --env-file=.env.local scripts/seed-bangalore-candidates.mjs",
    "db:backfill:votes": "node --env-file=.env.local scripts/backfill-votes.mjs",
    "db:migrate:insights": "node --env-file=.env.local scripts/migrate-insights.mjs",
    "scrape:myneta": "node scripts/scrape-myneta.mjs",
    "refresh:monthly": "node --env-file=.env.local scripts/monthly-refresh.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "maplibre-gl": "^4.7.1",
